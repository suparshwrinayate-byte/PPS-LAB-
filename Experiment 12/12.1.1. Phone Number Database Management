n=int(input().strip())
contacts={}
for _ in range(n):
	command=input().strip().split()

	if command[0]=='ADD':
		name=command[1]
		phone=command[2]

		contacts[name]=phone
	elif command [0]=='REMOVE':
		name=command[1]
		if name in contacts:
			del contacts[name]
	elif command[0]=='DISPLAY':
		if not contacts:
			print("No contacts")
		else:
			for name in sorted(contacts):
				print(f"{name}: {contacts[name]}")
